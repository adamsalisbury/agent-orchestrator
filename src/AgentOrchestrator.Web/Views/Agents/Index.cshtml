@model List<AgentOrchestrator.Web.Models.AgentViewModel>
@{
    ViewData["Title"] = "Team";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Team</h2>
    <a asp-action="Create" class="btn btn-primary">Add Team Member</a>
</div>

<div id="team-grid">
@if (!Model.Any())
{
    <div class="alert alert-info">
        No team members yet. Click <strong>Add Team Member</strong> to create one.
    </div>
}
else
{
    <div class="row">
        @foreach (var agent in Model)
        {
            var pulseClass = agent.IsBusy ? (agent.IsBlocked ? "card-pulse-blocked" : "card-pulse-busy") : "";
            <div class="col-12 col-md-4 mb-3">
                <div class="card h-100 @pulseClass">
                    <div class="card-body d-flex">
                        <div class="flex-shrink-0 me-3 position-relative">
                            <img src="@Url.Action("Avatar", "Agents", new { id = agent.Id })"
                                 alt="@agent.Name" width="80" height="80" class="rounded" />
                            @if (agent.IsBusy)
                            {
                                <span class="position-absolute top-0 start-0 translate-middle badge rounded-pill @(agent.IsBlocked ? "bg-warning text-dark" : "bg-danger")" style="font-size:0.6rem;">
                                    @(agent.IsBlocked ? "Blocked" : "Busy")
                                </span>
                            }
                            else
                            {
                                <span class="position-absolute top-0 start-0 translate-middle badge rounded-pill bg-secondary" style="font-size:0.6rem;">Idle</span>
                            }
                        </div>
                        <div class="flex-grow-1">
                            <h5 class="card-title mb-0">
                                @agent.Name
                                @if (agent.IsCeo)
                                {
                                    <span class="badge bg-warning text-dark ms-1" style="font-size:0.65rem;">CEO</span>
                                }
                                @if (agent.IsDeveloper)
                                {
                                    <span class="badge bg-success ms-1" style="font-size:0.65rem;">&lt;/&gt;</span>
                                }
                            </h5>
                            <small class="text-muted">@agent.JobTitle</small>
                            @if (agent.IsBusy && !string.IsNullOrEmpty(agent.CurrentTask))
                            {
                                <div class="mt-1">
                                    @if (agent.IsBlocked)
                                    {
                                        <small class="text-warning">
                                            <span class="spinner-grow spinner-grow-sm me-1" style="width:0.5rem;height:0.5rem;"></span>
                                            Waiting on @agent.BlockedByAgentName
                                        </small>
                                    }
                                    else
                                    {
                                        <small class="text-danger">
                                            <span class="spinner-border spinner-border-sm me-1" style="width:0.5rem;height:0.5rem;"></span>
                                            Working...
                                        </small>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <small class="text-muted"><code>@agent.Id</code></small>
                        <a asp-action="Detail" asp-route-id="@agent.Id" class="btn btn-sm btn-outline-primary">View</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
</div>

@section Scripts {
    <script>
        setInterval(function () {
            fetch(window.location.href)
                .then(function (res) { return res.text(); })
                .then(function (html) {
                    var parser = new DOMParser();
                    var doc = parser.parseFromString(html, "text/html");
                    var newGrid = doc.getElementById("team-grid");
                    if (newGrid) {
                        document.getElementById("team-grid").innerHTML = newGrid.innerHTML;
                    }
                })
                .catch(function () {});
        }, 5000);
    </script>
}
