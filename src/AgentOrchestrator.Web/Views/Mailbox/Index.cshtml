@model List<AgentOrchestrator.Web.Models.AgentViewModel>
@{
    ViewData["Title"] = "Agents";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Agents</h2>
    <div>
        <button type="button" class="btn btn-outline-danger me-2" data-bs-toggle="modal" data-bs-target="#resetModal">Reset Environment</button>
        <a asp-action="Create" class="btn btn-primary">Add Agent</a>
    </div>
</div>

<!-- Reset Confirmation Modal -->
<div class="modal fade" id="resetModal" tabindex="-1" aria-labelledby="resetModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="resetModalLabel">Reset Environment</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>This will <strong>permanently delete all agents and their messages</strong>.</p>
                <p class="mb-0">Are you sure you want to continue?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="ResetEnvironment" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Yes, delete everything</button>
                </form>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No agents yet. Click <strong>Add Agent</strong> to create one.
    </div>
}
else
{
    <div class="row">
        @foreach (var agent in Model)
        {
            <div class="col-12 col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body d-flex">
                        <div class="flex-shrink-0 me-3">
                            <img src="@Url.Action("Avatar", "Mailbox", new { id = agent.Id })"
                                 alt="@agent.Name" width="80" height="80" class="rounded" />
                        </div>
                        <div class="flex-grow-1">
                            <h5 class="card-title mb-0">@agent.Name</h5>
                            <small class="text-muted">@agent.JobTitle</small>
                            <p class="card-text small mt-1 mb-0" style="white-space: pre-wrap;">@(agent.Persona.Length > 100 ? agent.Persona[..100] + "..." : agent.Persona)</p>
                            @if (agent.Skills.Any())
                            {
                                <div class="mt-2 d-flex flex-wrap gap-1">
                                    @foreach (var skill in agent.Skills)
                                    {
                                        <span class="badge bg-info text-dark" style="font-size:0.75rem;">@skill</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <small class="text-muted"><code>@agent.Id</code></small>
                        <a asp-action="Requests" asp-route-id="@agent.Id" class="btn btn-sm btn-outline-primary">Requests</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
