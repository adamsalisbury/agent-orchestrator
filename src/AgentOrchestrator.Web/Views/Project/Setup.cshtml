@model AgentOrchestrator.Web.Models.EditProjectViewModel
@{
    ViewData["Title"] = "Setup";
    ViewData["HideNav"] = true;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <!-- Wizard Progress -->
        <div class="d-flex align-items-center mb-4">
            <div class="wizard-step active">
                <span class="wizard-number">1</span>
                <span class="wizard-label">Company</span>
            </div>
            <div class="wizard-connector"></div>
            <div class="wizard-step">
                <span class="wizard-number">2</span>
                <span class="wizard-label">Project</span>
            </div>
            <div class="wizard-connector"></div>
            <div class="wizard-step">
                <span class="wizard-number">3</span>
                <span class="wizard-label">Build Team</span>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h3 class="card-title mb-1">Welcome to Agent Studio</h3>
                <p class="text-muted mb-4">Let's get started. What's the name of your company or organisation?</p>

                <form asp-action="Setup" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label asp-for="CompanyName" class="form-label"><strong>Company Name</strong></label>
                        <input asp-for="CompanyName" class="form-control form-control-lg" placeholder="e.g. Acme Corp" />
                        <span asp-validation-for="CompanyName" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary btn-lg">
                            Next: Project Details &rarr;
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
