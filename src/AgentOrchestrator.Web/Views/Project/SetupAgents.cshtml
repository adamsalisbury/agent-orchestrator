@model AgentOrchestrator.Web.Models.SetupAgentsViewModel
@{
    ViewData["Title"] = "Build Your Team";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-10 col-lg-8">
        <!-- Wizard Progress -->
        <div class="d-flex align-items-center mb-4">
            <div class="wizard-step completed">
                <span class="wizard-number">&#10003;</span>
                <span class="wizard-label">Project Details</span>
            </div>
            <div class="wizard-connector completed"></div>
            <div class="wizard-step active">
                <span class="wizard-number">2</span>
                <span class="wizard-label">Build Team</span>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <h3 class="card-title mb-1">Build Your Team</h3>
                <p class="text-muted mb-0">
                    Project: <strong>@Model.ProjectName</strong>
                </p>
            </div>
        </div>

        <!-- Auto-Generate Section -->
        <div class="card mb-4" id="auto-generate-card">
            <div class="card-body">
                <h5 class="mb-2">Auto-Generate Team</h5>
                <p class="text-muted">
                    Analyse the project and build an organisation of 5-10 agents with a CEO and tailored roles.
                    Each agent gets a generated persona and skill set.
                </p>
                <button type="button" id="btn-auto-generate" class="btn btn-primary">
                    Generate Organisation
                </button>
            </div>
        </div>

        <!-- Auto-Generate Progress -->
        <div class="card mb-4" id="auto-progress-card" style="display:none;">
            <div class="card-body">
                <h5 class="mb-3">Building Organisation...</h5>

                <!-- Phase 1: Team Structure -->
                <div class="d-flex align-items-center mb-3" id="phase-structure">
                    <span class="spinner-border spinner-border-sm me-2" id="spin-structure"></span>
                    <span id="icon-structure" style="display:none;" class="me-2 text-success">&#10003;</span>
                    <span>Designing organisational structure...</span>
                </div>

                <!-- Phase 2: Agent creation progress -->
                <div id="agent-creation-list"></div>

                <div id="auto-progress-error" class="text-danger mt-2" style="display:none;"></div>
            </div>
        </div>

        <!-- Manual Add Section -->
        <div class="card mb-4" id="manual-add-card">
            <div class="card-body">
                <h5 class="mb-2">Add Agent Manually</h5>
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" id="manual-name" placeholder="e.g. Sarah" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Job Title</label>
                        <input type="text" class="form-control" id="manual-jobtitle" placeholder="e.g. Lead Designer" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Purpose</label>
                        <input type="text" class="form-control" id="manual-purpose" placeholder="Brief description..." />
                    </div>
                    <div class="col-md-2">
                        <button type="button" id="btn-manual-add" class="btn btn-outline-primary w-100">Add</button>
                    </div>
                </div>
                <div id="manual-error" class="text-danger small mt-2" style="display:none;"></div>
            </div>
        </div>

        <!-- Manual Add Progress Modal -->
        <div class="modal fade" id="manualProgressModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Creating Agent</h5>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3 d-flex align-items-center">
                            <span class="spinner-border spinner-border-sm me-2" id="manual-spin-persona"></span>
                            <span id="manual-icon-persona" style="display:none;" class="me-2 text-success">&#10003;</span>
                            <span>Generating persona &amp; skills...</span>
                        </div>
                        <div id="manual-progress-error" class="text-danger small" style="display:none;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Team Roster -->
        <div class="card mb-4" id="team-roster-card">
            <div class="card-body">
                <h5 class="mb-3">Team Roster <span class="badge bg-secondary" id="agent-count">@Model.Agents.Count</span></h5>

                <div id="team-roster">
                    @if (Model.Agents.Count == 0)
                    {
                        <p class="text-muted" id="empty-roster-msg">No agents yet. Use the options above to build your team.</p>
                    }
                    @foreach (var agent in Model.Agents)
                    {
                        <div class="d-flex align-items-center p-2 mb-2 border rounded agent-roster-row">
                            <img src="@Url.Action("Avatar", "Mailbox", new { id = agent.Id })" alt="avatar" width="40" height="40" class="rounded-circle me-3" />
                            <div class="flex-grow-1">
                                <strong>@agent.Name</strong> <span class="text-muted">— @agent.JobTitle</span>
                                <div class="mt-1">
                                    @foreach (var skill in agent.Skills)
                                    {
                                        <span class="badge bg-info text-dark me-1">@skill</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Finish -->
        <div class="d-flex justify-content-between mb-5">
            <a asp-action="Setup" class="btn btn-outline-secondary">&larr; Back to Project</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-success btn-lg" id="btn-finish">
                Finish Setup &rarr;
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var projectName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProjectName));
        var projectDescription = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProjectDescription));
        var agentCount = @Model.Agents.Count;

        function updateAgentCount() {
            document.getElementById("agent-count").textContent = agentCount;
        }

        function addAgentToRoster(agent) {
            var emptyMsg = document.getElementById("empty-roster-msg");
            if (emptyMsg) emptyMsg.remove();

            var roster = document.getElementById("team-roster");
            var row = document.createElement("div");
            row.className = "d-flex align-items-center p-2 mb-2 border rounded agent-roster-row";

            var avatarUrl = "@Url.Action("Avatar", "Mailbox", new { id = "__ID__" })".replace("__ID__", agent.id);
            var skillsHtml = (agent.skills || []).map(function(s) {
                return '<span class="badge bg-info text-dark me-1">' + escapeHtml(s) + '</span>';
            }).join("");

            var roleBadges = '';
            if (agent.isCeo) roleBadges += ' <span class="badge bg-warning text-dark" style="font-size:0.65rem;">CEO</span>';
            if (agent.isDeveloper) roleBadges += ' <span class="badge bg-success" style="font-size:0.65rem;">&lt;/&gt;</span>';
            row.innerHTML = '<img src="' + avatarUrl + '" alt="avatar" width="40" height="40" class="rounded-circle me-3" />' +
                '<div class="flex-grow-1">' +
                    '<strong>' + escapeHtml(agent.name) + '</strong>' + roleBadges + ' <span class="text-muted">\u2014 ' + escapeHtml(agent.jobTitle) + '</span>' +
                    (agent.reportsToName ? '<br/><small class="text-muted">Reports to: ' + escapeHtml(agent.reportsToName) + '</small>' : '') +
                    '<div class="mt-1">' + skillsHtml + '</div>' +
                '</div>';

            roster.appendChild(row);
            agentCount++;
            updateAgentCount();
        }

        function escapeHtml(text) {
            var div = document.createElement("div");
            div.textContent = text;
            return div.innerHTML;
        }

        // --- Auto-Generate ---
        document.getElementById("btn-auto-generate").addEventListener("click", function () {
            var btn = this;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Generating...';

            document.getElementById("auto-progress-card").style.display = "";
            document.getElementById("spin-structure").style.display = "";
            document.getElementById("icon-structure").style.display = "none";
            document.getElementById("agent-creation-list").innerHTML = "";
            document.getElementById("auto-progress-error").style.display = "none";

            var headers = { "Content-Type": "application/json" };
            var body = JSON.stringify({ projectName: projectName, projectDescription: projectDescription });

            // Step 1: Get team structure
            fetch("@Url.Action("GenerateTeamStructure", "Project")", { method: "POST", headers: headers, body: body })
            .then(function (res) { return res.json().then(function (d) { return { ok: res.ok, data: d }; }); })
            .then(function (result) {
                if (!result.ok || !result.data.roles) throw new Error(result.data.error || "Failed to generate team structure");

                // Structure done
                document.getElementById("spin-structure").style.display = "none";
                document.getElementById("icon-structure").style.display = "";

                var roles = result.data.roles;

                // Build progress list for each agent
                var listEl = document.getElementById("agent-creation-list");
                roles.forEach(function (role, i) {
                    var item = document.createElement("div");
                    item.className = "d-flex align-items-center mb-2 ms-3";
                    item.id = "agent-progress-" + i;
                    var badges = '';
                    if (!role.reportsTo) badges += ' <span class="badge bg-warning text-dark" style="font-size:0.65rem;">CEO</span>';
                    if (role.isDeveloper) badges += ' <span class="badge bg-success" style="font-size:0.65rem;">&lt;/&gt;</span>';
                    item.innerHTML = '<span class="spinner-border spinner-border-sm me-2 agent-spin" style="display:none;"></span>' +
                        '<span class="me-2 text-success agent-icon" style="display:none;">&#10003;</span>' +
                        '<span class="me-2 text-muted agent-waiting">&#9679;</span>' +
                        '<span>' + escapeHtml(role.name) + ' \u2014 ' + escapeHtml(role.jobTitle) + badges + '</span>';
                    listEl.appendChild(item);
                });

                // Step 2: Create agents sequentially
                return createAgentsSequentially(roles, 0);
            })
            .then(function () {
                btn.innerHTML = 'Organisation Generated';
                btn.className = "btn btn-success";
            })
            .catch(function (err) {
                document.getElementById("spin-structure").style.display = "none";
                document.getElementById("auto-progress-error").textContent = err.message;
                document.getElementById("auto-progress-error").style.display = "";
                btn.disabled = false;
                btn.innerHTML = 'Generate Organisation';
            });
        });

        function createAgentsSequentially(roles, index) {
            if (index >= roles.length) return Promise.resolve();

            var role = roles[index];
            var el = document.getElementById("agent-progress-" + index);
            var spin = el.querySelector(".agent-spin");
            var icon = el.querySelector(".agent-icon");
            var waiting = el.querySelector(".agent-waiting");

            waiting.style.display = "none";
            spin.style.display = "";

            var headers = { "Content-Type": "application/json" };
            var isCeo = !role.reportsTo;
            var body = JSON.stringify({
                name: role.name,
                jobTitle: role.jobTitle,
                purpose: role.purpose,
                reportsTo: role.reportsTo || null,
                isDeveloper: role.isDeveloper || false,
                isCeo: isCeo
            });

            return fetch("@Url.Action("CreateAgentFromRole", "Project")", { method: "POST", headers: headers, body: body })
            .then(function (res) { return res.json().then(function (d) { return { ok: res.ok, data: d }; }); })
            .then(function (result) {
                spin.style.display = "none";
                if (!result.ok || !result.data.success) {
                    icon.textContent = "\u2717";
                    icon.className = "me-2 text-danger agent-icon";
                    icon.style.display = "";
                    // Continue with next agent even on failure
                } else {
                    icon.style.display = "";
                    addAgentToRoster(result.data.agent);
                }
                return createAgentsSequentially(roles, index + 1);
            });
        }

        // --- Manual Add ---
        document.getElementById("btn-manual-add").addEventListener("click", function () {
            var name = document.getElementById("manual-name").value.trim();
            var jobTitle = document.getElementById("manual-jobtitle").value.trim();
            var purpose = document.getElementById("manual-purpose").value.trim();
            var errorDiv = document.getElementById("manual-error");
            errorDiv.style.display = "none";

            if (!name || !jobTitle) {
                errorDiv.textContent = "Name and Job Title are required.";
                errorDiv.style.display = "";
                return;
            }

            // Show progress modal
            document.getElementById("manual-spin-persona").style.display = "";
            document.getElementById("manual-icon-persona").style.display = "none";
            document.getElementById("manual-progress-error").style.display = "none";
            var modal = new bootstrap.Modal(document.getElementById("manualProgressModal"));
            modal.show();

            var headers = { "Content-Type": "application/json" };
            var body = JSON.stringify({ name: name, jobTitle: jobTitle, purpose: purpose });

            fetch("@Url.Action("CreateAgentFromRole", "Project")", { method: "POST", headers: headers, body: body })
            .then(function (res) { return res.json().then(function (d) { return { ok: res.ok, data: d }; }); })
            .then(function (result) {
                if (!result.ok || !result.data.success) throw new Error(result.data.error || "Failed to create agent");

                document.getElementById("manual-spin-persona").style.display = "none";
                document.getElementById("manual-icon-persona").style.display = "";

                addAgentToRoster(result.data.agent);

                // Clear form
                document.getElementById("manual-name").value = "";
                document.getElementById("manual-jobtitle").value = "";
                document.getElementById("manual-purpose").value = "";

                setTimeout(function () { modal.hide(); }, 500);
            })
            .catch(function (err) {
                document.getElementById("manual-spin-persona").style.display = "none";
                document.getElementById("manual-progress-error").textContent = err.message;
                document.getElementById("manual-progress-error").style.display = "";
                setTimeout(function () { modal.hide(); }, 2000);
            });
        });
    </script>
}
