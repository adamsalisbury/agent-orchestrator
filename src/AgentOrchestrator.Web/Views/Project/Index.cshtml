@model AgentOrchestrator.Web.Models.ProjectViewModel
@{
    ViewData["Title"] = "Project";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">@Model.Name</h2>
        <small class="text-muted">@Model.CompanyName</small>
    </div>
    <a asp-action="Edit" class="btn btn-outline-secondary">Edit</a>
</div>

<div class="card mb-3">
    <div class="card-header"><strong>Description</strong></div>
    <div class="card-body">
        <pre class="mb-0" style="white-space: pre-wrap; font-family: inherit;">@Model.Description</pre>
    </div>
</div>

<!-- File Browsers -->
<div class="row mb-3">
    <div class="col-md-6 mb-2">
        <div class="card h-100">
            <div class="card-body text-center">
                <h5>&lt;/&gt; Workspace</h5>
                <p class="text-muted small mb-2">Browse the code written by the development team.</p>
                <a asp-action="Workspace" class="btn btn-outline-success">&lt;/&gt; Open Workspace</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-2">
        <div class="card h-100">
            <div class="card-body text-center">
                <h5>Shared Space</h5>
                <p class="text-muted small mb-2">Specifications, API contracts, and coordination files.</p>
                <a asp-action="SharedSpace" class="btn btn-outline-info">Open Shared Space</a>
            </div>
        </div>
    </div>
</div>

<!-- Team -->
<div class="card mb-3">
    <div class="card-header"><strong>Team</strong> <span class="badge bg-secondary">@Model.Agents.Count</span></div>
    <div class="card-body">
        @if (!Model.Agents.Any())
        {
            <p class="text-muted mb-0">No team members yet. <a asp-controller="Agents" asp-action="Create">Add a team member</a>.</p>
        }
        else
        {
            <div class="row">
                @foreach (var agent in Model.Agents)
                {
                    <div class="col-12 col-md-6 mb-2">
                        <div class="d-flex align-items-center">
                            <img src="@Url.Action("Avatar", "Agents", new { id = agent.Id })"
                                 alt="@agent.Name" width="36" height="36" class="rounded me-2" />
                            <div class="flex-grow-1">
                                <strong>@agent.Name</strong>
                                <small class="text-muted d-block">@agent.JobTitle</small>
                            </div>
                            <a asp-controller="Agents" asp-action="Detail" asp-route-id="@agent.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
